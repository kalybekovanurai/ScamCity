rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /scenarios/{scenarioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /meta/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
