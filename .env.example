# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase web config for the app.
VITE_FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="scamcity-c2cf1.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="scamcity-c2cf1"
VITE_FIREBASE_STORAGE_BUCKET="scamcity-c2cf1.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"

# Firestore seed script.
# Use either GOOGLE_APPLICATION_CREDENTIALS with a service account file path,
# or FIREBASE_SERVICE_ACCOUNT_KEY with the full service account JSON.
FIREBASE_PROJECT_ID="scamcity-c2cf1"
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Backend API.
# In local development, leave VITE_API_URL empty so Vite proxies /api without browser CORS.
VITE_API_URL=""
VITE_API_BASE_URL="https://nonfissile-pomaceous-anita.ngrok-free.dev"

# Data source mode for the frontend demo.
# Allowed values: api | mock | auto
# Vite-native variables:
VITE_DATA_SOURCE="auto"
VITE_SHOW_DEMO_BADGE="true"

# Vercel-friendly aliases. These work because vite.config.ts enables NEXT_PUBLIC_ envPrefix.
NEXT_PUBLIC_DATA_SOURCE="auto"
NEXT_PUBLIC_SHOW_DEMO_BADGE="true"
